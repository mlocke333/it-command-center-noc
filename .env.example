# ─────────────────────────────────────────────────────────────────────────
#  NOC Command Center — environment configuration
# ─────────────────────────────────────────────────────────────────────────
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
#  Secrets belong in a vault (Azure Key Vault, GitHub Actions secrets), not in
#  source and never in API responses. The wall runs on MOCK data by default.
#  Live integrations must run server-side; never expose secrets to the browser.
# ─────────────────────────────────────────────────────────────────────────

# Data source: "mock" (default) or "live"
VITE_DATA_SOURCE=mock

# How often the wall polls for fresh data, in seconds
VITE_REFRESH_SECONDS=10

# Backend origin. Empty = same origin (SWA managed Functions). Set to your
# Container App URL when using the push service on a different origin.
VITE_API_BASE=

# Alert feed transport: "poll" (SWA-friendly) or "sse" (Container Apps push)
VITE_EVENT_TRANSPORT=poll

# ── Live backend (server-side only — no VITE_ prefix for secrets) ─────────
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MERAKI_API_KEY=
NSIGHT_API_KEY=
NSIGHT_REGION=
